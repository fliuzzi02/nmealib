{
  "name": "nmealib",
  "version": "0.7.0",
  "description": "Modern C++20 library for parsing NMEA 0183 sentences and NMEA 2000 CAN messages.",
  "keywords": [
    "nmea",
    "nmea0183",
    "nmea2000",
    "gps",
    "marine",
    "parser"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/fliuzzi02/nmealib.git"
  },
  "homepage": "https://github.com/fliuzzi02/nmealib",
  "authors": [
    {
      "name": "Federico Liuzzi",
      "url": "https://github.com/fliuzzi02",
      "maintainer": true
    }
  ],
  "license": "MIT",
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "platforms": [
    "espressif32",
    "espressif8266"
  ],
  "headers": [
    "nmealib.h"
  ],
  "build": {
    "flags": [
      "-std=gnu++20",
      "-fno-exceptions",
      "-DNMEALIB_NO_EXCEPTIONS"
    ]
  },
  "export": {
    "exclude": [
      ".github",
      "tests",
      "docs",
      "out",
      "app",
      "scripts/cppcheck_summary.py",
      "CMakePresets.json"
    ]
  }
}
